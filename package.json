{
  "name": "into-place",
  "private": true,
  "type": "module",
  "scripts": {
    "cutout": "node scripts/cutout.mjs",
    "preprocess": "node --env-file-if-exists=.env.local scripts/batch-cutout.mjs",
    "preprocess:review": "node scripts/preprocess-contact-sheet.mjs",
    "test:preprocess": "node --test tests/*.test.mjs tests/*.test.mts tests/preprocess/*.test.mjs",
    "experiment": "node --env-file-if-exists=.env.local --import tsx scripts/run-experiment.mjs",
    "sync-public": "node scripts/sync-public.mjs",
    "dev": "node scripts/sync-public.mjs && next dev",
    "build": "node scripts/sync-public.mjs && next build",
    "start": "next start"
  },
  "dependencies": {
    "@fal-ai/client": "^1.2.0",
    "next": "^15.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-globe.gl": "^2.38.0",
    "server-only": "^0.0.1",
    "sharp": "^0.33.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.185.1",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.33.5": true,
    "@google/genai@1.52.0": true,
    "esbuild@0.25.12": true,
    "onnxruntime-node@1.23.2": true,
    "sharp@0.34.5": true,
    "protobufjs@7.6.5": true
  }
}
